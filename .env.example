# Datadog RUM access
DD_API_KEY=your_datadog_api_key
DD_APP_KEY=your_datadog_application_key
DD_SITE=datadoghq.com

# LLM provider — set ONE of these. ADK prefers Claude when ANTHROPIC_API_KEY is set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=anthropic/claude-opus-4-7
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Deepchecks instrumentation — app_name must be pre-created in the Deepchecks UI.
DEEPCHECKS_API_TOKEN=
DEEPCHECKS_HOST=https://app.llm.deepchecks.com/
DEEPCHECKS_APP_NAME=datadog-frustration-agent
DEEPCHECKS_VERSION=v0.1.0
DEEPCHECKS_ENV=EVAL
DEEPCHECKS_LOG_TO_CONSOLE=0
